{
  "name": "training-collection",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal training database of styles, exercises, and routines centered on Dorian Yates' Blood & Guts.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
